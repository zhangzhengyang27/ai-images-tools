{
  "name": "ai-images-tools",
  "version": "2.0.0",
  "description": "图片压缩工具 - 本地图片压缩桌面应用",
  "main": "./out/main/index.cjs",
  "type": "module",
  "author": "ai-images-tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhangzhengyang27/ai-images-tools.git"
  },
  "homepage": "https://github.com/ai-images-tools",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "install-electron && electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:all": "pnpm run build && electron-builder --win --mac",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.5",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "sharp": "^0.34.5",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@primevue/themes": "^4.5.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp",
      "@tailwindcss/vite"
    ]
  }
}
